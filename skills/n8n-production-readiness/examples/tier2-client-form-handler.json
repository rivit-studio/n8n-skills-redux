          }
        ],
        [
          {
            "node": "400 Response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Save to Database": {
      "main": [
        [
          {
            "node": "Notify Team",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Notify Team": {
      "main": [
        [
          {
            "node": "200 Response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "200 Response": {
      "main": [
        [
          {
